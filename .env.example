# App
APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Email delivery - Resend fallback/provider
EMAIL_SEND_MODE=mock
EMAIL_TEST_RECIPIENT=
ALLOW_LIVE_EMAIL_SENDS=false
RESEND_API_KEY=
NEXT_PUBLIC_FROM_EMAIL=Columb Outreach <onboarding@resend.dev>

# Email delivery - SMTP reference/defaults
# Current app SMTP accounts are stored per workspace in the database.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Columb Outreach <noreply@example.com>

# Scheduled/background jobs
CRON_SECRET=replace-with-a-long-random-secret
