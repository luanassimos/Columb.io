# App
APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Email safety
# mock: never calls SMTP/Resend.
# dry_run: compiles/processes without provider calls.
# live: real delivery, blocked unless ALLOW_LIVE_EMAIL_SENDS=true.
EMAIL_SEND_MODE=mock
EMAIL_TEST_RECIPIENT=
ALLOW_LIVE_EMAIL_SENDS=false

# Email delivery - Resend fallback/provider
RESEND_API_KEY=
NEXT_PUBLIC_FROM_EMAIL=Columb Outreach <onboarding@resend.dev>

# Email delivery - SMTP reference/defaults
# Current app SMTP accounts are stored per workspace in the database.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Columb Outreach <noreply@example.com>

# Scheduled/background jobs
# Required for cron/background calls to /api/send as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace-with-a-long-random-secret

# AI Lead Intelligence
# V1 uses mock only. Do not add real provider keys here.
AI_PROVIDER=mock
AI_MODEL=
AI_DAILY_LEAD_LIMIT=50
AI_MAX_EVIDENCE_CHARS=6000
AI_ENABLE_WEBSITE_FETCH=false
AI_ENABLE_SOCIAL_FETCH=false
AI_REQUIRE_HUMAN_APPROVAL=true
